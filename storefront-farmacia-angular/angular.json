{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "cli": {
    "analytics": false,
    "cache": {
      "enabled": true,
      "environment": "local",
      "path": ".angular/cache"
    },
    "packageManager": "npm",
    "warnings": {
      "versionMismatch": true
    }
  },
  "schematics": {
    "@schematics/angular:component": {
      "standalone": true,
      "style": "css",
      "skipTests": false
    },
    "@schematics/angular:directive": {
      "standalone": true
    }
  },
  "projects": {
    "storefront-farmacia-angular": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "laf",
      "schematics": {
        "@schematics/angular:component": {
          "standalone": true,
          "style": "css",
          "skipTests": false
        }
      },
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/storefront-farmacia-angular",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "scripts": []
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kb",
                  "maximumError": "1mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "8kb",
                  "maximumError": "16kb"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "storefront-farmacia-angular:build:production"
            },
            "development": {
              "buildTarget": "storefront-farmacia-angular:build:development",
              "proxyConfig": "proxy.conf.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "storefront-farmacia-angular:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "karmaConfig": "karma.conf.js",
            "watch": false,
            "browsers": "ChromeHeadlessCI",
            "styles": [
              "src/styles.css"
            ],
            "scripts": [],
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "/"
              }
            ]
          }
        }
      }
    }
  }
}

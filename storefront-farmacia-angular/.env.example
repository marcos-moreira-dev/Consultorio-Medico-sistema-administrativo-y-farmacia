# Storefront Angular - archivo de referencia para onboarding.
# Angular CLI no lee .env automáticamente en esta etapa.
# Estas variables documentan valores esperados hasta que el runtime config se cablee desde src.
APP_ENV=local
FRONTEND_PORT=4200
PUBLIC_API_BASE_URL=http://localhost:3001/api/v1
PUBLIC_MEDIA_BASE_URL=http://localhost:3001/media
PUBLIC_BRAND_NAME=La Alameda Farma
PUBLIC_CURRENCY=USD
PUBLIC_API_TIMEOUT_MS=15000

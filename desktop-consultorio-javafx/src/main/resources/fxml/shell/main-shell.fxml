<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dev.marcosmoreira.desktopconsultorio.shell.controller.MainShellController"
            prefHeight="760.0"
            prefWidth="1180.0"
            styleClass="shell-root">

    <top>
        <VBox>
            <MenuBar fx:id="menuBar">
                <Menu text="Archivo">
                    <MenuItem fx:id="menuCerrarSesion" text="Cerrar sesión" onAction="#onLogout"/>
                    <MenuItem fx:id="menuSalir" text="Salir" onAction="#onSalir"/>
                </Menu>
                <Menu text="Ver">
                    <MenuItem fx:id="menuPantallaCompleta" text="Pantalla completa (F11)" onAction="#onPantallaCompleta"/>
                    <MenuItem fx:id="menuRecargar" text="Recargar vista actual (Ctrl+R)" onAction="#onRecargar"/>
                </Menu>
                <Menu text="Ayuda">
                    <MenuItem fx:id="menuAcercaDe" text="Acerca de Santa Emilia Desktop" onAction="#onAcercaDe"/>
                </Menu>
            </MenuBar>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="topbar">
                <padding>
                    <Insets top="12" right="18" bottom="12" left="18"/>
                </padding>
                <VBox spacing="3">
                    <Label text="Modo" styleClass="field-label"/>
                    <Label text="Operación local" styleClass="muted-label"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox spacing="3">
                    <Label text="Sesión" styleClass="field-label"/>
                    <Label fx:id="sessionLabel"/>
                </VBox>
                <VBox spacing="3">
                    <Label text="Rol" styleClass="field-label"/>
                    <Label fx:id="roleLabel"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox prefWidth="252" styleClass="sidebar">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <ImageView fx:id="sidebarLogoImageView" fitHeight="38" fitWidth="38" preserveRatio="true" smooth="true" />
                <VBox spacing="2">
                    <Label fx:id="appTitleLabel" wrapText="true" maxWidth="186" styleClass="sidebar-title"/>
                    <Label text="Operación" styleClass="muted-label"/>
                </VBox>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="4">
                <Button fx:id="dashboardButton" maxWidth="9999.0" text="Dashboard" onAction="#onDashboard" styleClass="sidebar-button"/>
                <Button fx:id="usuariosButton" maxWidth="9999.0" text="Usuarios" onAction="#onUsuarios" styleClass="sidebar-button"/>
                <Button fx:id="pacientesButton" maxWidth="9999.0" text="Pacientes" onAction="#onPacientes" styleClass="sidebar-button"/>
                <Button fx:id="citasButton" maxWidth="9999.0" text="Citas" onAction="#onCitas" styleClass="sidebar-button"/>
                <Button fx:id="cobrosButton" maxWidth="9999.0" text="Cobros" onAction="#onCobros" styleClass="sidebar-button"/>
                <Button fx:id="profesionalesButton" maxWidth="9999.0" text="Profesionales" onAction="#onProfesionales" styleClass="sidebar-button"/>
                <Button fx:id="atencionesButton" maxWidth="9999.0" text="Atenciones" onAction="#onAtenciones" styleClass="sidebar-button"/>
                <Button fx:id="reportesButton" maxWidth="9999.0" text="Reportes" onAction="#onReportes" styleClass="sidebar-button"/>
                <Button fx:id="auditoriaButton" maxWidth="9999.0" text="Auditoría" onAction="#onAuditoria" styleClass="sidebar-button"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="8">
                <Button fx:id="logoutButton" text="Cerrar sesión" maxWidth="9999.0" onAction="#onLogout" styleClass="sidebar-button-logout"/>
                <VBox spacing="10" alignment="CENTER" styleClass="sidebar-brand-panel">
                    <ImageView fx:id="sidebarBrandLargeImageView" fitHeight="92" fitWidth="160" preserveRatio="true" smooth="true" />
                </VBox>
            </VBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="12" styleClass="content-wrapper">
            <padding>
                <Insets top="18" right="20" bottom="18" left="20"/>
            </padding>
            <Label fx:id="contentTitleLabel" styleClass="content-title"/>
            <Label fx:id="contentSubtitleLabel" wrapText="true" styleClass="muted-label"/>
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll">
                <content>
                    <VBox fx:id="contentBox" spacing="10" prefWidth="860"/>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
